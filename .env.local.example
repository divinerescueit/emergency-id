# Copy this file to .env.local for local development.
# In production (Vercel), set these in Project Settings -> Environment Variables.

# Found in Supabase: Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Found in Supabase: Project Settings -> API -> Project API keys -> service_role
# IMPORTANT: This key bypasses Row Level Security. NEVER expose it to the browser
# or commit it to git. It is only used in server-side code (pages/api, getServerSideProps).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Base URL of your deployed site, used to build the QR code link.
# For local dev: http://localhost:3000
# For production: https://your-app.vercel.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
